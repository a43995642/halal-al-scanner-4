{
  "entities": {
    "Report": {
      "title": "Report",
      "description": "A user report for incorrect AI analysis.",
      "type": "object",
      "properties": {
        "user_id": {
          "type": "string",
          "description": "The ID of the user who submitted the report. Can be null."
        },
        "original_text": {
          "type": "string",
          "description": "The original text that was analyzed."
        },
        "ai_result": {
          "type": "object",
          "description": "The result returned by the AI."
        },
        "user_correction": {
          "type": "string",
          "description": "The user's suggested correction."
        },
        "user_notes": {
          "type": "string",
          "description": "Additional notes from the user."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the report was created."
        }
      }
    },
    "UserStats": {
      "title": "UserStats",
      "description": "Statistics for a user.",
      "type": "object",
      "properties": {
        "scanCount": {
          "type": "number",
          "description": "The number of scans the user has performed."
        }
      }
    },
    "IngredientCache": {
      "title": "IngredientCache",
      "description": "Cache for ingredient analysis.",
      "type": "object",
      "properties": {
        "result": {
          "type": "object",
          "description": "The cached result."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the cache was created."
        }
      }
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": {
        "$ref": "#/entities/Report"
      },
      "description": "Stores user reports."
    },
    "/user_stats/{userId}": {
      "schema": {
        "$ref": "#/entities/UserStats"
      },
      "description": "Stores user statistics."
    },
    "/ingredient_cache/{ingredientId}": {
      "schema": {
        "$ref": "#/entities/IngredientCache"
      },
      "description": "Stores cached ingredient analysis."
    }
  }
}
